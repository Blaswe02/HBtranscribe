# Kopieer dit bestand naar .env en vul je eigen sleutels in
# Vraag een Gemini API key aan op: https://aistudio.google.com/apikey

# Verplicht — voor alle transcriptie via Gemini
GEMINI_API_KEY=jouw-gemini-api-key-hier

# Alleen nodig voor "Hoge kwaliteit" modus (AssemblyAI + Supabase)
# VITE_SUPABASE_URL=https://<project-ref>.supabase.co
# VITE_SUPABASE_ANON_KEY=<your-supabase-anon-key>
# VITE_ASSEMBLYAI_API_KEY=<your-assemblyai-api-key>
